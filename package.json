{
  "name": "e-ide",
  "version": "1.0.0",
  "description": "E-IDE - 新一代智能体IDE，用最简洁的架构做最牛逼的产品",
  "main": "dist/main.js",
  "author": "水哥 - 青岛理工大学 2022级",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -w --project tsconfig.main.json",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc --project tsconfig.main.json",
    "build:renderer": "vite build",
    "electron": "electron .",
    "start": "npm run build && npm run electron",
    "pack": "npm run build && set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& electron-builder --dir --x64 --ia32",
    "dist": "npm run build && set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& npx @electron/packager . E-IDE --platform=win32 --arch=x64,ia32 --out=pkg-out --overwrite --no-prune --ignore=\"^build-out$\" --ignore=\"^pkg-out$\" --ignore=\"^dist-exe$\" --ignore=\"^dist-pkg$\" --ignore=\"^\\\\.idea$\" --ignore=\"^\\\\.git$\" --ignore=\"^README\\\\.md$\" --ignore=\"^scripts$\" --ignore=\"^sfx-launcher\\\\.cs$\" --ignore=\"^build-sfx\\\\.js$\" --ignore=\"^e-ide\\\\.png$\" --ignore=\"^e-ide\\\\.ico$\"",
    "dist:portable": "npm run dist && node scripts/make-portable.js",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.shui-ge.e-ide",
    "productName": "E-IDE",
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "E-IDE"
    }
  },
  "keywords": [
    "ide",
    "editor",
    "typescript",
    "electron"
  ],
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@electron/packager": "^20.0.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "codemirror": "^6.0.2",
    "concurrently": "^8.2.2",
    "electron": "^22.3.27",
    "electron-builder": "^26.8.1",
    "eslint": "^8.56.0",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.60.0",
    "@vscode/debugprotocol": "^1.60.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.6.0",
    "simple-git": "^3.19.0",
    "ssh2": "^1.15.0",
    "vscode-languageserver": "^8.0.0",
    "vscode-languageserver-protocol": "^3.17.0",
    "vscode-languageserver-textdocument": "^1.0.11",
    "xterm": "^5.3.0"
  }
}
